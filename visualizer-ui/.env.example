# Study harness environment variables.
# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# Next.js loads .env files from the project root (visualizer-ui/), not from src/.

# Supabase, SERVER-ONLY. These must NOT be prefixed with NEXT_PUBLIC_ so they are
# never sent to the browser. The service role key bypasses RLS and is used only
# by the API route handlers.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public Microsoft Forms questionnaire URL shown on the final handoff screen.
NEXT_PUBLIC_MSFORMS_URL=
